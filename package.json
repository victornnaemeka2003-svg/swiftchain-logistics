{
  "name": "swiftchain-logistics",
  "version": "1.0.0",
  "description": "Modern, production-ready full-stack logistics company web application",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon --exec node --experimental-modules server.js",
    "client:dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js"
  },
  "keywords": ["logistics", "shipping", "tracking", "full-stack"],
  "author": "SwiftChain",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "mysql2": "^3.6.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.13.0",
    "csv-writer": "^1.6.0",
    "nodemailer": "^6.9.6",
    "chart.js": "^4.4.0",
    "uuid": "^9.0.0",
    "validator": "^13.11.0",
    "helmet": "^7.0.0",
    "express-rate-limit": "^7.0.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.1"
  }
}
